# ============================================================
#  Norris Decking & Sheds – Production Environment Variables
#  Copy this file to .env.production and fill in every value.
#  NEVER commit .env.production to git.
# ============================================================

# -- Database ---------------------------------------------------
# SQLite file inside the Docker data volume (do not change the path)
DATABASE_URL="file:/app/data/prod.db"

# -- Auth -------------------------------------------------------
# Generate a strong random secret:  openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET"

# The URL visitors (and the server itself) use to reach the site
NEXTAUTH_URL="http://192.168.1.26:3010"

# Trust the host header (required when running behind a local IP or reverse proxy)
AUTH_TRUST_HOST=true

# -- Admin seed account ----------------------------------------
# Used by the /api/seed route on first run only
ADMIN_EMAIL="jason@norrisdeckingandheds.com.au"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Jason Norris"

# -- Email notifications ----------------------------------------
# Enquiry alert recipient (Jason's inbox)
NOTIFY_EMAIL="j.norris86@hotmail.com"

# SMTP – fill in with your cPanel / provider details
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
