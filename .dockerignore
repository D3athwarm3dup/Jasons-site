# Dependencies – reinstalled inside the image
node_modules

# Next.js build output – rebuilt inside the image
.next

# Local database – a production DB lives in the Docker volume
*.db
*.db-shm
*.db-wal

# Environment files (never bake secrets into the image)
.env
.env.*
!.env.production.example

# Dev / editor artefacts
.git
.gitignore
*.md
.vscode
.idea

# OS artefacts
.DS_Store
Thumbs.db

# Uploads folder – mounted as a Docker volume at runtime
public/uploads
